# =============================================================================
# InstaPET — Environment Variables
# Copy to backend/.env for local development
# =============================================================================

# --- LOCAL DEVELOPMENT (default) ---
NODE_ENV=development
HOST=0.0.0.0
PORT=1338

APP_KEYS=changeMe1,changeMe2,changeMe3,changeMe4
API_TOKEN_SALT=changeMeApiTokenSalt
ADMIN_JWT_SECRET=changeMeAdminJwtSecret
TRANSFER_TOKEN_SALT=changeMeTransferTokenSalt
JWT_SECRET=changeMeJwtSecret
ENCRYPTION_KEY=changeMeEncryptionKey

# Database — SQLite for local
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Upload — local disk for development
UPLOAD_PROVIDER=local
UPLOAD_MAX_FILE_BYTES=5242880
UPLOAD_MAX_FILES_PER_REQUEST=10
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp
UPLOAD_UNUSED_RETENTION_HOURS=24

# CORS — Flutter web on localhost
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:8080

PUBLIC_API_URL=http://localhost:1338

# Seed demo data on first bootstrap (when no posts exist)
SEED_DATA=true
# Set true to wipe demo posts/media and reseed (10 users, 100 posts)
SEED_FORCE=false

# --- PRODUCTION (DigitalOcean + Managed PostgreSQL + Cloudflare R2) ---
# NODE_ENV=production
# DATABASE_CLIENT=postgres
# DATABASE_URL=${managed-db.DATABASE_URL}
# DATABASE_SSL=true
# UPLOAD_PROVIDER=cloudflare-r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=instapet-production
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL=https://media.instapet.example
# PUBLIC_API_URL=https://api.instapet.example
# CORS_ORIGINS=https://app.instapet.example
# SEED_DATA=false
